# Copy this file to ".env" and fill in your key.
# .env is read automatically by compare.py. Never commit your real .env.

# The Odds API — free tier 500 requests/month: https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here

# Anthropic API — for football intelligence analysis (form, injuries, conditions)
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Polymarket Gamma API: public read access, NO key needed.
# Kalshi: public market-data reads need NO key. (Trading would need one.)
