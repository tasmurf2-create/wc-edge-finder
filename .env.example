# Copy this file to ".env" and fill in your key.
# .env is read automatically by compare.py. Never commit your real .env.

# The Odds API — free tier 500 requests/month: https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here

# Anthropic API — for football intelligence analysis (form, injuries, conditions)
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Polymarket Gamma API: public read access, NO key needed.
# Kalshi: public market-data reads need NO key. (Trading would need one.)

# --- Optional tuning (paid Odds API plan) ---
# How often to refresh odds in the background (minutes). Default 15.
# Set to 0 to disable auto-refresh and use the frugal 2h request-driven cache
# (free-tier behaviour). Floor is 5 minutes.
#ODDS_REFRESH_MINUTES=15

# Odds API regions to request. Default "uk" (covers Irish-accessible books).
# Widen on the paid plan e.g. "uk,eu" — also widen BOOKMAKER_WHITELIST below.
#ODDS_REGIONS=uk

# Comma-separated bookmakers to show. Default is the Irish-books set:
#BOOKMAKER_WHITELIST=Paddy Power,Betfair,Betfair Exchange,Bet365,BoyleSports,Ladbrokes,William Hill
